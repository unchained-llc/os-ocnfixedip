<model>
    <mount>//OPNsense/dslite</mount>
    <description>DS-Lite (Dual-Stack Lite) tunnel configuration</description>
    <version>1.0.0</version>
    <items>
        <enabled type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </enabled>
        <isp_profile type="OptionField">
            <Default>auto</Default>
            <Required>Y</Required>
            <OptionValues>
                <auto>Auto-detect (from prefix)</auto>
                <transix>Transix (Internet Multifeed)</transix>
                <xpass>Xpass (ARTERIA Networks)</xpass>
                <v6connect>v6 Connect (NTT Smart Connect)</v6connect>
                <custom>Custom</custom>
            </OptionValues>
        </isp_profile>
        <wan_interface type="InterfaceField">
            <Required>Y</Required>
            <AllowDynamic>1</AllowDynamic>
            <filters>
                <enable>/^1$/</enable>
            </filters>
        </wan_interface>
        <aftr_address type="NetworkField">
            <Required>N</Required>
            <NetMaskAllowed>N</NetMaskAllowed>
            <AddressFamily>IPv6</AddressFamily>
        </aftr_address>
        <aftr_hostname type="HostnameField">
            <Required>N</Required>
        </aftr_hostname>
        <b4_address type="NetworkField">
            <Default>192.0.0.2</Default>
            <Required>Y</Required>
            <NetMaskAllowed>N</NetMaskAllowed>
            <AddressFamily>IPv4</AddressFamily>
        </b4_address>
        <aftr_v4_address type="NetworkField">
            <Default>192.0.0.1</Default>
            <Required>Y</Required>
            <NetMaskAllowed>N</NetMaskAllowed>
            <AddressFamily>IPv4</AddressFamily>
        </aftr_v4_address>
        <mtu type="IntegerField">
            <Default>1460</Default>
            <Required>Y</Required>
            <MinimumValue>1280</MinimumValue>
            <MaximumValue>9000</MaximumValue>
        </mtu>
        <mss_clamp type="IntegerField">
            <Default>1420</Default>
            <Required>Y</Required>
            <MinimumValue>536</MinimumValue>
            <MaximumValue>8960</MaximumValue>
        </mss_clamp>
        <nat_enabled type="BooleanField">
            <Default>1</Default>
            <Required>Y</Required>
        </nat_enabled>
    </items>
</model>
